CREATE DATABASE IF NOT EXISTS EcoStyle;
USE EcoStyle;
-- =====================================================
-- CORE TABLES
-- =====================================================
CREATE TABLE categories (
  category_id INT AUTO_INCREMENT PRIMARY KEY,
  name VARCHAR(100) NOT NULL,
  description VARCHAR(255)
) ENGINE=InnoDB;
CREATE TABLE suppliers (
  supplier_id INT AUTO_INCREMENT PRIMARY KEY,
  company_name VARCHAR(150) NOT NULL,
  country_of_origin VARCHAR(100) NOT NULL,
  contact_email VARCHAR(150) NOT NULL,
  phone VARCHAR(30),
  environmental_certification VARCHAR(100),
  sustainability_rating DECIMAL(3,1) DEFAULT 0.0,
  active TINYINT(1) NOT NULL DEFAULT 1
) ENGINE=InnoDB;
CREATE TABLE materials (
  material_id INT AUTO_INCREMENT PRIMARY KEY,
  supplier_id INT NOT NULL,
  name VARCHAR(150) NOT NULL,
  origin_type VARCHAR(80),
  recycled_percentage DECIMAL(5,2) DEFAULT 0.00,
  unit_cost_per_kg DECIMAL(10,2) NOT NULL DEFAULT 0.00,
  carbon_footprint_kg_co2 DECIMAL(10,3) NOT NULL DEFAULT 0.000,
  CONSTRAINT fk_materials_suppliers
    FOREIGN KEY (supplier_id) REFERENCES suppliers(supplier_id)
) ENGINE=InnoDB;
CREATE TABLE products (
  product_id INT AUTO_INCREMENT PRIMARY KEY,
  category_id INT NOT NULL,
  name VARCHAR(150) NOT NULL,
  description VARCHAR(255),
  size VARCHAR(20),
  color VARCHAR(50),
  price DECIMAL(10,2) NOT NULL DEFAULT 0.00,
  stock INT NOT NULL DEFAULT 0,
  carbon_footprint_kg_co2 DECIMAL(10,3) NOT NULL DEFAULT 0.000,
  active TINYINT(1) NOT NULL DEFAULT 1,
  CONSTRAINT fk_products_categories
    FOREIGN KEY (category_id) REFERENCES categories(category_id)
) ENGINE=InnoDB;
CREATE TABLE product_material (
  product_id INT NOT NULL,
  material_id INT NOT NULL,
  percentage_in_product DECIMAL(5,2) NOT NULL,
  PRIMARY KEY (product_id, material_id),
  CONSTRAINT fk_product_material_product
    FOREIGN KEY (product_id) REFERENCES products(product_id),
  CONSTRAINT fk_product_material_material
    FOREIGN KEY (material_id) REFERENCES materials(material_id)
) ENGINE=InnoDB;
CREATE TABLE clothing (
  clothing_id INT AUTO_INCREMENT PRIMARY KEY,
  product_id INT NOT NULL,
  clothing_name VARCHAR(250) NOT NULL,
  production_city VARCHAR(300) NOT NULL,
  characteristics VARCHAR(200),
  CONSTRAINT fk_clothing_products
    FOREIGN KEY (product_id) REFERENCES products(product_id)
) ENGINE=InnoDB;
CREATE TABLE stock_status (
  quality VARCHAR(100) PRIMARY KEY,
  quantity INT NOT NULL
) ENGINE=InnoDB;
CREATE TABLE recycled_items (
  recycled_id INT AUTO_INCREMENT PRIMARY KEY,
  defects INT NOT NULL,
  quality_label VARCHAR(100)
) ENGINE=InnoDB;
CREATE TABLE customers (
  customer_id INT AUTO_INCREMENT PRIMARY KEY,
  name VARCHAR(100) NOT NULL,
  email VARCHAR(150) NOT NULL,
  phone VARCHAR(20),
  nif VARCHAR(20),
  birth_date DATE,
  active TINYINT(1) NOT NULL DEFAULT 1
) ENGINE=InnoDB;
CREATE TABLE addresses (
  address_id INT AUTO_INCREMENT PRIMARY KEY,
  customer_id INT NOT NULL,
  address_type ENUM('shipping','billing') NOT NULL,
  street VARCHAR(255) NOT NULL,
  city VARCHAR(100) NOT NULL,
  postal_code VARCHAR(20) NOT NULL,
  country VARCHAR(100) NOT NULL,
  is_primary TINYINT(1) NOT NULL DEFAULT 0,
  CONSTRAINT fk_addresses_customers
    FOREIGN KEY (customer_id) REFERENCES customers(customer_id)
) ENGINE=InnoDB;
CREATE TABLE carriers (
  carrier_id INT AUTO_INCREMENT PRIMARY KEY,
  name VARCHAR(150) NOT NULL,
  carbon_neutral TINYINT(1) NOT NULL DEFAULT 0,
  compensation_program VARCHAR(255),
  average_shipping_cost DECIMAL(10,2) NOT NULL DEFAULT 0.00
) ENGINE=InnoDB;
CREATE TABLE orders (
  order_id INT AUTO_INCREMENT PRIMARY KEY,
  customer_id INT NOT NULL,
  address_id INT NOT NULL,
  status VARCHAR(50) NOT NULL,
  total_value DECIMAL(10,2) NOT NULL DEFAULT 0.00,
  CONSTRAINT fk_orders_customers
    FOREIGN KEY (customer_id) REFERENCES customers(customer_id),
  CONSTRAINT fk_orders_addresses
    FOREIGN KEY (address_id) REFERENCES addresses(address_id)
) ENGINE=InnoDB;
CREATE TABLE order_items (
  order_item_id INT AUTO_INCREMENT PRIMARY KEY,
  order_id INT NOT NULL,
  product_id INT NOT NULL,
  quantity INT NOT NULL,
  unit_price DECIMAL(10,2) NOT NULL,
  CONSTRAINT fk_order_items_orders
    FOREIGN KEY (order_id) REFERENCES orders(order_id),
  CONSTRAINT fk_order_items_products
    FOREIGN KEY (product_id) REFERENCES products(product_id)
) ENGINE=InnoDB;
CREATE TABLE deliveries (
  delivery_id INT AUTO_INCREMENT PRIMARY KEY,
  order_id INT NOT NULL,
  carrier_id INT NOT NULL,
  tracking_code VARCHAR(80) NOT NULL,
  shipping_date DATETIME NULL,
  expected_delivery_date DATE NULL,
  actual_delivery_date DATETIME NULL,
  delivery_status VARCHAR(50) NOT NULL,
  carbon_footprint_kg_co2 DECIMAL(10,3) NOT NULL DEFAULT 0.000,
  carbon_compensated_kg DECIMAL(10,3) NOT NULL DEFAULT 0.000,
  CONSTRAINT fk_deliveries_orders
    FOREIGN KEY (order_id) REFERENCES orders(order_id),
  CONSTRAINT fk_deliveries_carriers
    FOREIGN KEY (carrier_id) REFERENCES carriers(carrier_id)
) ENGINE=InnoDB;
CREATE TABLE payments (
  payment_id INT AUTO_INCREMENT PRIMARY KEY,
  order_id INT NOT NULL,
  method VARCHAR(50) NOT NULL,
  amount DECIMAL(10,2) NOT NULL,
  status VARCHAR(50) NOT NULL,
  CONSTRAINT fk_payments_orders
    FOREIGN KEY (order_id) REFERENCES orders(order_id)
) ENGINE=InnoDB;
CREATE TABLE returns_table (
  return_id INT AUTO_INCREMENT PRIMARY KEY,
  order_item_id INT NOT NULL,
  reason VARCHAR(100) NOT NULL,
  description VARCHAR(255),
  status VARCHAR(50) NOT NULL,
  refund_amount DECIMAL(10,2) NULL,
  resolved_at DATETIME NULL,
  CONSTRAINT fk_returns_order_items
    FOREIGN KEY (order_item_id) REFERENCES order_items(order_item_id)
) ENGINE=InnoDB;
-- =====================================================
-- EXTRA TABLES BASED ON THE ORIGINAL IDEA
-- =====================================================
CREATE TABLE loan_records (
  loan_id INT AUTO_INCREMENT PRIMARY KEY,
  overdue_days INT NOT NULL DEFAULT 0,
  days_in_use INT NOT NULL DEFAULT 0,
  paid TINYINT(1) NOT NULL DEFAULT 0
) ENGINE=InnoDB;
CREATE TABLE physical_loans (
  physical_loan_id INT AUTO_INCREMENT PRIMARY KEY,
  value DECIMAL(10,2) NOT NULL DEFAULT 0.00,
  duration VARCHAR(100) NOT NULL
) ENGINE=InnoDB;
CREATE TABLE fines (
  fine_id INT AUTO_INCREMENT PRIMARY KEY,
  overdue_days INT NOT NULL DEFAULT 0,
  fee_amount DECIMAL(10,2) NOT NULL DEFAULT 0.00
) ENGINE=InnoDB;
CREATE TABLE returns_notes (
  note_id INT AUTO_INCREMENT PRIMARY KEY,
  damaged_clothes VARCHAR(200),
  wrong_size VARCHAR(200),
  customer_order_id INT NULL,
  CONSTRAINT fk_returns_notes_orders
    FOREIGN KEY (customer_order_id) REFERENCES orders(order_id)
) ENGINE=InnoDB;
