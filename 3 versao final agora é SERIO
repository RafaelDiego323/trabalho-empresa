CREATE DATABASE IF NOT EXISTS LibraryTech
    CHARACTER SET utf8mb4
    COLLATE utf8mb4_general_ci;
 
USE LibraryTech;
 
 
CREATE TABLE BookLoans (
    book_id     INT AUTO_INCREMENT NOT NULL,
    overdue     DECIMAL(10,2) NOT NULL DEFAULT 0,   -- fixed: DECIMAL(10,200) was invalid
    loan_days   INT NOT NULL,
    paid        TINYINT(1) NOT NULL,
    CONSTRAINT pk_book_loans PRIMARY KEY (book_id)
);
 
 
CREATE TABLE PhysicalLoans (
    id        INT AUTO_INCREMENT PRIMARY KEY,
    book_id   INT NOT NULL,
    value     INT NOT NULL,
    loan_date DATE NOT NULL,
    CONSTRAINT fk_physical_loans_books
        FOREIGN KEY (book_id) REFERENCES BookLoans(book_id)
);
 
 
 
CREATE TABLE CopyManagement (
    id        INT AUTO_INCREMENT PRIMARY KEY,
    book_id   INT NOT NULL,
    stock     INT NOT NULL,
    CONSTRAINT fk_copy_management_books
        FOREIGN KEY (book_id) REFERENCES BookLoans(book_id)
);
 
 
CREATE TABLE Status (
    id                 INT AUTO_INCREMENT PRIMARY KEY,
    book_id            INT NOT NULL,
    store_location      VARCHAR(200),
    book_order_quantity INT NOT NULL,
    CONSTRAINT fk_status_books
        FOREIGN KEY (book_id) REFERENCES BookLoans(book_id)
);
 
 
CREATE TABLE Conservation (
    id              INT AUTO_INCREMENT PRIMARY KEY,
    book_id         INT NOT NULL,
    book_damage     VARCHAR(100),
    quality         INT NOT NULL,
    book_condition  VARCHAR(100),
    CONSTRAINT fk_conservation_books
        FOREIGN KEY (book_id) REFERENCES BookLoans(book_id)
);
 
 
CREATE TABLE Authors (
    id             INT AUTO_INCREMENT PRIMARY KEY,
    book_id        INT NOT NULL,
    author_name    VARCHAR(100),
    book_age       INT NOT NULL,
    book_rarity    VARCHAR(50),
    CONSTRAINT fk_authors_books
        FOREIGN KEY (book_id) REFERENCES BookLoans(book_id)
);
 
CREATE TABLE Fines (
    fine_id     INT NOT NULL AUTO_INCREMENT,
    book_id     INT NOT NULL,
    delay_time  INT NOT NULL,
    fee         INT NOT NULL,
    new_column  INT,
    CONSTRAINT pk_fines PRIMARY KEY (fine_id),
    CONSTRAINT fk_fines_books
        FOREIGN KEY (book_id) REFERENCES BookLoans(book_id)
);
 
