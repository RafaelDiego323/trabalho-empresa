CREATE TABLE IF NOT EXISTS FinesLog (
    id           INT AUTO_INCREMENT PRIMARY KEY,
    time_id      INT NOT NULL,
    old_time     INT,
    new_time     INT,
    change_date  TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
 
 
 
DROP TRIGGER IF EXISTS update_fines_insert;
DROP TRIGGER IF EXISTS update_fines_update;
 
DELIMITER $$
 
-- Logs the fine as soon as it is created (no "old time" exists yet)
CREATE TRIGGER update_fines_insert
AFTER INSERT ON Fines
FOR EACH ROW
BEGIN
    INSERT INTO FinesLog (time_id, old_time, new_time)
    VALUES (NEW.fine_id, NULL, NEW.delay_time);
END$$
 
-- Logs the change only if the delay time actually changed
CREATE TRIGGER update_fines_update
AFTER UPDATE ON Fines
FOR EACH ROW
BEGIN
    IF OLD.delay_time <> NEW.delay_time THEN
        INSERT INTO FinesLog (time_id, old_time, new_time)
        VALUES (OLD.fine_id, OLD.delay_time, NEW.delay_time);
    END IF;
END$$
 
DELIMITER ;
 
 
 
 
