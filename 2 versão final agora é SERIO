CREATE DATABASE MedPet;
CREATE DATABASE MedPet;
USE MedPet;


CREATE TABLE appointments(
appointment_id INT NOT NULL,
scheduled_appointments VARCHAR(100),
doctor_names VARCHAR(800),
available_slots VARCHAR(800),
CONSTRAINT PK_appointments PRIMARY KEY (appointment_id)
);


CREATE TABLE hospitalizations(
hospitalized_patients VARCHAR(800),
surgery_scheduled INT,
open_slots INT NOT NULL,
CONSTRAINT FK_hospitalizations FOREIGN KEY (appointment_id)
);


CREATE TABLE medical_history(

appointment_list VARCHAR(800),
vaccines VARCHAR(800),
allergies VARCHAR(800),
diseases VARCHAR(800),
CONSTRAINT PK_medical_history PRIMARY KEY (vaccines)
);


CREATE TABLE owners(

owner_name VARCHAR(800),
dog_id INT AUTO_INCREMENT NOT NULL,
amount_due DECIMAL(50,90),
CONSTRAINT PK_owners PRIMARY KEY (dog_id)
);


CREATE TABLE MedicalStaff(
doctor_name VARCHAR(800),
dog_name VARCHAR(100),
breed VARCHAR(50),
weight INT(50),
age INT(30),
CONSTRAINT PK_MedicalStaff PRIMARY KEY (dog_name)
);

CREATE TABLE revenue(
revenue_amount DECIMAL(8,100),
daily_average VARCHAR(400),
monthly_average DECIMAL(1000,1000000),
yearly_average DECIMAL(1000,1000000) NOT NULL,
CONSTRAINT FK_medical_history FOREIGN KEY (vaccines),
CONSTRAINT FK_hospitalizations FOREIGN KEY (appointment_id),
CONSTRAINT FK_owners FOREIGN KEY (dog_id),
CONSTRAINT PK_revenue PRIMARY KEY (revenue_amount)
);

CREATE TABLE expenses (
taxes INT AUTO_INCREMENT NOT NULL,
medication_expenses INT AUTO_INCREMENT NOT NULL,
tax_authority_share INT AUTO_INCREMENT NOT NULL,
CONSTRAINT FK_revenue FOREIGN KEY (revenue_amount),
)

