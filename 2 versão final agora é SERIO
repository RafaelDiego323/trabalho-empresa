CREATE PROCEDURE sp_sleyerpoint(
    IN p_ProductID VARCHAR(100)
)

BEGIN
    SELECT 
      appointment_id, scheduled_appointments, doctor_names, available_slots, appointment_list, vaccines, allergies, diseases  STATUS 
    FROM appointment_id_scheduled_appointments_doctor_names
    INNER JOIN available_slots_appointment_list_vaccines ON appointment_id_scheduled_appointments_doctor_names.available_slots=available_slots_appointment_list_vaccines_allergies_diseases
    WHERE appointment_id=c_appointment_id;
END 

