CREATE TABLE IF NOT EXISTS log_multas (
    id             INT AUTO_INCREMENT PRIMARY KEY,
    id_tempo       INT NOT NULL,
    tempo_antigo   INT,
    tempo_novo     INT,
    data_alteracao TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);



DROP TRIGGER IF EXISTS atualiza_multas_insert;
DROP TRIGGER IF EXISTS atualiza_multas_update;

DELIMITER $$

-- Registra a multa assim que ela é criada (não existe "tempo antigo" ainda)
CREATE TRIGGER atualiza_multas_insert
AFTER INSERT ON multas
FOR EACH ROW
BEGIN
    INSERT INTO log_multas (id_tempo, tempo_antigo, tempo_novo)
    VALUES (NEW.valoradicionalid, NULL, NEW.tempodeatrazo);
END$$

-- Registra a alteração apenas se o tempo de atraso realmente mudou
CREATE TRIGGER atualiza_multas_update
AFTER UPDATE ON multas
FOR EACH ROW
BEGIN
    IF OLD.tempodeatrazo <> NEW.tempodeatrazo THEN
        INSERT INTO log_multas (id_tempo, tempo_antigo, tempo_novo)
        VALUES (OLD.valoradicionalid, OLD.tempodeatrazo, NEW.tempodeatrazo);
    END IF;
END$$

DELIMITER ;




