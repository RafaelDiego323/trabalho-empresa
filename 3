CREATE DATABASE IF NOT EXISTS BiblioTech
    CHARACTER SET utf8mb4
    COLLATE utf8mb4_general_ci;
 
USE BiblioTech;
 

CREATE TABLE Emprestimosdelivros (
    livrosid   INT AUTO_INCREMENT NOT NULL,
    atrazados  DECIMAL(10,2) NOT NULL DEFAULT 0,   -- corrigido: DECIMAL(10,200) era inválido
    emdai      INT NOT NULL,
    pagas      TINYINT(1) NOT NULL,
    CONSTRAINT pk_Emprestimos PRIMARY KEY (livrosid)
);
 

CREATE TABLE Emprestimosfisicos (
    id        INT AUTO_INCREMENT PRIMARY KEY,
    livrosid  INT NOT NULL,
    valor     INT NOT NULL,
    tempo     date not null,
    CONSTRAINT fk_Emprestimosfisicos_livros
        FOREIGN KEY (livrosid) REFERENCES Emprestimosdelivros(livrosid)
);
 



CREATE TABLE gestaodeexemplares (
    id        INT AUTO_INCREMENT PRIMARY KEY,
    livrosid  INT NOT NULL,
    estoque   INT NOT NULL,
    CONSTRAINT fk_gestao_livros
        FOREIGN KEY (livrosid) REFERENCES Emprestimosdelivros(livrosid)
);
 

CREATE TABLE estados (
    id                INT AUTO_INCREMENT PRIMARY KEY,
    livrosid          INT NOT NULL,
    lojasdoestados    VARCHAR(200),
    encomendadolivro  INT NOT NULL,
    CONSTRAINT fk_estados_livros
        FOREIGN KEY (livrosid) REFERENCES Emprestimosdelivros(livrosid)
);
 

CREATE TABLE conservacao (
    id              INT AUTO_INCREMENT PRIMARY KEY,
    livrosid        INT NOT NULL,
    danosnolivros   VARCHAR(100),
    qualidade       INT NOT NULL,
    tempodolivro    VARCHAR(100),
    CONSTRAINT fk_conservacao_livros
        FOREIGN KEY (livrosid) REFERENCES Emprestimosdelivros(livrosid)
);
 

CREATE TABLE autores (
    id                INT AUTO_INCREMENT PRIMARY KEY,
    livrosid          INT NOT NULL,
    autorname         VARCHAR(100),
    idadedilivro      INT NOT NULL,
    raridadedolivro   VARCHAR(50),
    CONSTRAINT fk_autores_livros
        FOREIGN KEY (livrosid) REFERENCES Emprestimosdelivros(livrosid)
);
 
CREATE TABLE multas (
    valoradicionalid INT NOT NULL AUTO_INCREMENT,
    livrosid         INT NOT NULL,
    tempodeatrazo    INT NOT NULL,
    taxa             INT NOT NULL,
    nova_coluna      INT,
    CONSTRAINT pk_multas PRIMARY KEY (valoradicionalid),
    CONSTRAINT fk_multas_livros
        FOREIGN KEY (livrosid) REFERENCES Emprestimosdelivros(livrosid)
);
 
